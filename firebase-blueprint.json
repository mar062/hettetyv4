{
  "entities": {
    "UserProfile": {
      "title": "User Profile",
      "description": "Stores user information and preferences",
      "type": "object",
      "properties": {
        "uid": { "type": "string", "description": "Firebase Auth UID" },
        "name": { "type": "string", "description": "Full name" },
        "email": { "type": "string", "description": "Email address" },
        "phone": { "type": "string", "description": "Phone number" },
        "role": { "type": "string", "enum": ["user", "admin"], "description": "User role" },
        "preferences": { "type": "string", "description": "User property preferences" },
        "createdAt": { "type": "string", "format": "date-time", "description": "Account creation timestamp" }
      },
      "required": ["uid", "email", "role"]
    },
    "Property": {
      "title": "Property",
      "description": "Real estate property listing",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "title": { "type": "string" },
        "price": { "type": "number" },
        "location": { "type": "string" },
        "bedrooms": { "type": "number" },
        "bathrooms": { "type": "number" },
        "area": { "type": "number" },
        "imageUrl": { "type": "string" },
        "status": { "type": "string", "enum": ["For Sale", "For Rent"] },
        "isVerified": { "type": "boolean" },
        "paymentMethods": { "type": "array", "items": { "type": "string" } },
        "authorUid": { "type": "string" }
      },
      "required": ["title", "price", "location", "status"]
    },
    "UserDocument": {
      "title": "User Document",
      "description": "Legal documents uploaded by users",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "fileId": { "type": "string" },
        "name": { "type": "string" },
        "type": { "type": "string" },
        "status": { "type": "string" },
        "uploadDate": { "type": "string" },
        "accessStatus": { "type": "string" },
        "size": { "type": "number" },
        "content": { "type": "string" },
        "ownerUid": { "type": "string" }
      },
      "required": ["name", "ownerUid", "content"]
    }
  },
  "firestore": {
    "/users/{uid}": {
      "schema": "UserProfile",
      "description": "User profile documents"
    },
    "/properties/{propertyId}": {
      "schema": "Property",
      "description": "Property listing documents"
    },
    "/user_documents/{docId}": {
      "schema": "UserDocument",
      "description": "User uploaded legal documents"
    }
  }
}
