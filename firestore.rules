rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    
    // ===============================================================
    // Assumed Data Model
    // ===============================================================
    //
    // Collection: users
    // Document ID: uid (Firebase Auth UID)
    // Fields:
    //   - uid: string (required) - Firebase Auth UID
    //   - name: string (optional) - Full name
    //   - email: string (required) - Email address
    //   - phone: string (optional) - Phone number
    //   - role: string (required, enum: ['user', 'admin']) - User role
    //   - preferences: string (optional) - User property preferences
    //   - createdAt: timestamp (optional) - Account creation timestamp
    //
    // Collection: properties
    // Document ID: propertyId
    // Fields:
    //   - id: string (optional) - Property ID
    //   - title: string (required) - Property title
    //   - price: number (required) - Property price
    //   - location: string (required) - Property location
    //   - bedrooms: number (optional) - Number of bedrooms
    //   - bathrooms: number (optional) - Number of bathrooms
    //   - area: number (optional) - Area in sqm
    //   - imageUrl: string (optional) - Image URL
    //   - status: string (required, enum: ['For Sale', 'For Rent']) - Property status
    //   - isVerified: bool (optional) - Whether the property is verified
    //   - paymentMethods: list (optional) - List of payment methods
    //   - authorUid: string (optional) - UID of the user who created the listing
    //
    // ===============================================================

    // ===============================================================
    // Helper Functions
    // ===============================================================
    
    function isAuthenticated() {
      return request.auth != null;
    }
    
    function isOwner(userId) {
      return isAuthenticated() && request.auth.uid == userId;
    }
    
    function isAdmin() {
      return isAuthenticated() && 
        (get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'admin' || 
         isSuperAdmin());
    }

    function isSuperAdmin() {
      return isAuthenticated() && 
        (request.auth.token.email == "marwaneltaweel0@gmail.com" ||
         request.auth.token.email == "abdallahahmedpilot2426@gmail.com");
    }

    function isValidUser(data) {
      return data.keys().hasOnly(['uid', 'name', 'email', 'role', 'createdAt', 'phone', 'preferences']) &&
             data.keys().hasAll(['uid', 'email', 'role']) &&
             data.uid is string && data.uid.size() < 100 &&
             data.email is string && data.email.size() < 255 &&
             data.role in ['user', 'admin'] &&
             (!('name' in data) || (data.name is string && data.name.size() < 255)) &&
             (!('createdAt' in data) || (data.createdAt is string && data.createdAt.size() < 100) || data.createdAt is timestamp) &&
             (!('phone' in data) || (data.phone is string && data.phone.size() < 50)) &&
             (!('preferences' in data) || (data.preferences is string && data.preferences.size() < 10000));
    }

    function isValidProperty(data) {
      return data.keys().hasOnly(['title', 'price', 'location', 'bedrooms', 'bathrooms', 'area', 'imageUrl', 'videoUrl', 'status', 'isVerified', 'verificationStatus', 'paymentMethods', 'publishDate', 'unitCode', 'legalDocs', 'authorUid']) &&
             data.keys().hasAll(['title', 'price', 'location', 'status']) &&
             data.title is string && data.title.size() > 0 && data.title.size() < 200 &&
             data.price is number && data.price >= 0 &&
             data.location is string && data.location.size() > 0 &&
             data.status in ['For Sale', 'For Rent'] &&
             (!('bedrooms' in data) || data.bedrooms is number) &&
             (!('bathrooms' in data) || data.bathrooms is number) &&
             (!('area' in data) || data.area is number) &&
             (!('imageUrl' in data) || (data.imageUrl is string && data.imageUrl.size() < 2000)) &&
             (!('videoUrl' in data) || (data.videoUrl is string && data.videoUrl.size() < 2000)) &&
             (!('isVerified' in data) || data.isVerified is bool) &&
             (!('verificationStatus' in data) || data.verificationStatus in ['Pending', 'Verified', 'Rejected']) &&
             (!('paymentMethods' in data) || (data.paymentMethods is list && data.paymentMethods.size() <= 10)) &&
             (!('publishDate' in data) || (data.publishDate is string && data.publishDate.size() < 50)) &&
             (!('unitCode' in data) || (data.unitCode is string && data.unitCode.size() < 50)) &&
             (!('legalDocs' in data) || (data.legalDocs is list && data.legalDocs.size() <= 10)) &&
             (!('authorUid' in data) || data.authorUid is string);
    }

    function isValidNotification(data) {
      return data.keys().hasOnly(['userId', 'title', 'message', 'date', 'read']) &&
             data.keys().hasAll(['userId', 'title', 'message', 'date', 'read']) &&
             data.userId is string &&
             data.title is string && data.title.size() < 200 &&
             data.message is string && data.message.size() < 1000 &&
             data.date is string && data.date.size() < 50 &&
             data.read is bool;
    }

    function isValidUserDocument(data) {
      return data.keys().hasOnly(['fileId', 'name', 'type', 'status', 'uploadDate', 'accessStatus', 'size', 'content', 'ownerUid', 'storagePath']) &&
             data.keys().hasAll(['name', 'ownerUid', 'content']) &&
             data.name is string && data.name.size() > 0 && data.name.size() < 255 &&
             data.ownerUid is string &&
             data.content is string && data.content.size() > 0 && data.content.size() < 1048576 &&
             (!('fileId' in data) || (data.fileId is string && data.fileId.size() < 100)) &&
             (!('type' in data) || (data.type is string && data.type.size() < 50)) &&
             (!('status' in data) || (data.status is string && data.status.size() < 50)) &&
             (!('uploadDate' in data) || (data.uploadDate is string && data.uploadDate.size() < 50)) &&
             (!('accessStatus' in data) || (data.accessStatus is string && data.accessStatus.size() < 50)) &&
             (!('size' in data) || data.size is number) &&
             (!('storagePath' in data) || (data.storagePath is string && data.storagePath.size() < 1000));
    }

    function uidNotModified() {
      return !('uid' in request.resource.data) || request.resource.data.uid == resource.data.uid;
    }

    function ownerUidNotModified() {
      return !('ownerUid' in request.resource.data) || request.resource.data.ownerUid == resource.data.ownerUid;
    }

    // ===============================================================
    // Match Rules
    // ===============================================================

    match /users/{userId} {
      allow read: if isOwner(userId) || isAdmin();
      allow list: if isAdmin();
      allow create: if isAuthenticated() && isOwner(userId) && isValidUser(request.resource.data) && (request.resource.data.role == 'user' || isSuperAdmin());
      allow update: if (isOwner(userId) && isValidUser(request.resource.data) && uidNotModified() && (request.resource.data.role == resource.data.role || isSuperAdmin())) || 
                    (isSuperAdmin() && isValidUser(request.resource.data) && uidNotModified());
      allow delete: if isSuperAdmin();
    }

    match /properties/{propertyId} {
      allow read, list: if true;
      allow create: if isAdmin() && isValidProperty(request.resource.data);
      allow update: if isAdmin() && isValidProperty(request.resource.data);
      allow delete: if isAdmin();
    }

    match /user_documents/{docId} {
      allow read, delete: if isAuthenticated() && (resource.data.ownerUid == request.auth.uid || isAdmin());
      allow create: if isAuthenticated() && request.resource.data.ownerUid == request.auth.uid && isValidUserDocument(request.resource.data);
      allow update: if isAuthenticated() && (resource.data.ownerUid == request.auth.uid || isAdmin()) && isValidUserDocument(request.resource.data) && ownerUidNotModified();
    }

    match /notifications/{notificationId} {
      allow read: if isAuthenticated() && resource.data.userId == request.auth.uid;
      allow create: if isAdmin() && isValidNotification(request.resource.data);
      allow update: if isAuthenticated() && resource.data.userId == request.auth.uid && isValidNotification(request.resource.data) && request.resource.data.userId == resource.data.userId;
      allow delete: if isAuthenticated() && resource.data.userId == request.auth.uid;
    }
  }
}
